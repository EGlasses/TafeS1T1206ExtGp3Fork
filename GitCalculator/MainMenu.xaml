<Page
    x:Class="Calculator.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="LightBlue">

	<Grid>

		<!-- Title - MainMenu -->
		<TextBlock Text="Universal Calculator"
                   FontSize="55"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,30,0,0"
                   FontWeight="SemiBold"/>

		<!-- Logo -->
		<Image Source="/Images/abacus.jpg"
               Width="360"
               Height="360"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,20,30,0"/>

		<!-- Center Calculator Buttons -->
		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="300">

			<Button Content="Math Calculator"
                    Width="300"
					Height="150"
					FontSize="30"
                    Margin="0,10"/>

			<Button Content="Mortgage Calculator"
                    Width="300"
					Height="150"
					FontSize="30"
                    Margin="0,10"/>

			<Button Content="Currency Calculator"
                    Width="300"
					Height="150"
					FontSize="30"
                    Margin="0,10"/>

			<Button Content="Exit"
                    Width="300"
					Height="150"
					FontSize="30"
                    Margin="0,10"/>

		</StackPanel>

		<!-- Left Trip Button -->
		<Button Content="Trip Calculator"
                Width="300"
                Height="150"
				FontSize="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="180,0,0,0"/>

	</Grid>
</Page>
